<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Background Image / Gradient Effect (Simulating the dark scenery) -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_header_gradient"
        android:alpha="0.5"/>

    <!-- Glassmorphism Main Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/glass_card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="48dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/glass_bg_trans"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/accent_cobra"
        app:strokeWidth="1.5dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Title: Cobra style (White + Red) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Hi, Welcome to"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="4dp"
                android:text="FilterX"
                android:textColor="@color/accent_cobra"
                android:textSize="44sp"
                android:textStyle="bold"
                android:shadowColor="@color/accent_cobra"
                android:shadowRadius="15"
                android:shadowDx="0"
                android:shadowDy="0" />

            <!-- Active Status (Matched colors professionally) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="horizontal">
                
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@android:drawable/ic_secure"
                    app:tint="@color/accent_cobra" />
                    
                <TextView
                    android:id="@+id/status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:text="PROTECTION ACTIVE"
                    android:textColor="@color/accent_cobra"
                    android:textSize="11sp"
                    android:letterSpacing="0.05"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="24dp"
                android:background="#33FFFFFF" />

            <!-- Recycler View for Messages (Taking up the middle space) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_messages"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false" />

            <!-- Empty State -->
            <LinearLayout
                android:id="@+id/empty_state_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@android:drawable/ic_dialog_email"
                    app:tint="@color/accent_cobra"
                    android:alpha="0.8"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Inbox Clear"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />
            </LinearLayout>

            <View
                android:layout_width="100dp"
                android:layout_height="2dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginVertical="24dp"
                android:background="#33FFFFFF" />

            <!-- Cobra Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:gravity="center">

                <!-- Clear Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:paddingHorizontal="0dp"
                    android:text="Clear"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="25dp"
                    app:strokeColor="@color/white"
                    app:strokeWidth="1dp" />

                <!-- Engine Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_train"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="4dp"
                    android:paddingHorizontal="0dp"
                    android:text="Engine"
                    android:textColor="@color/text_dark"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="@color/white"
                    app:cornerRadius="25dp" />

                <!-- Config Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_settings"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:paddingHorizontal="0dp"
                    android:text="Config"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="25dp"
                    app:strokeColor="@color/white"
                    app:strokeWidth="1dp" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
